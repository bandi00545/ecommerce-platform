# lombok.config — Root configuration for Lombok
# This file must be at the Maven project root.
# Eclipse reads this to configure Lombok annotation processing.

# Prevent Lombok from scanning parent directories for another lombok.config
config.stopBubbling = true

# Add @lombok.Generated annotation to all generated methods
# Allows Eclipse/JaCoCo to exclude generated code from coverage reports
lombok.addLombokGeneratedAnnotation = true

# Use SLF4J as the logging framework for @Slf4j
# This must match the logging dependency in each service pom.xml
lombok.log.slf4j.flagUsage = ALLOW

# Suppress warnings for fields that are set by Lombok but appear unused to Eclipse
lombok.extern.findbugs.addSuppressFBWarnings = true

# Generate @ConstructorProperties for @AllArgsConstructor and @RequiredArgsConstructor
# Required for Jackson deserialization of Lombok-generated constructors
lombok.anyConstructor.addConstructorProperties = true
