# =============================================================================
# .env.example — Copy this to .env and fill in real values
# NEVER commit .env with real secrets
# =============================================================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# JWT — must be at least 256 bits (32 chars)
JWT_SECRET=replace-with-a-very-long-random-secret-key-at-least-32-chars

# Config Server credentials
CONFIG_SERVER_USER=configuser
CONFIG_SERVER_PASSWORD=your-config-server-password

# Eureka credentials
EUREKA_USER=eurekauser
EUREKA_PASSWORD=your-eureka-password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Payment simulation (0.0 = never fail, 1.0 = always fail)
PAYMENT_FAILURE_RATE=0.1

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=prod
