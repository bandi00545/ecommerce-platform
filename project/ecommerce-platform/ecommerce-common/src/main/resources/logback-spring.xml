<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ======================================================================
         LOGBACK CONFIGURATION - ecommerce-common
         
         All microservices include this via ecommerce-common dependency.
         Each service can override by placing their own logback-spring.xml.
         
         PATTERN EXPLANATION:
         %d{yyyy-MM-dd HH:mm:ss.SSS} - timestamp
         [%thread]                    - thread name
         %-5level                     - log level (padded to 5 chars: DEBUG, INFO, WARN, ERROR)
         [%X{requestId:-NO_REQ_ID}]  - MDC requestId (set by RequestContextFilter)
         [%X{userId:-anonymous}]     - MDC userId (set by RequestContextFilter)
         %logger{50}                  - logger name (max 50 chars)
         - %msg                       - the actual log message
         %n                           - newline
         ======================================================================= -->

    <!-- =====================================================================
         PROPERTIES
         ================================================================== -->
    <springProperty scope="context" name="APP_NAME"
                    source="spring.application.name" defaultValue="ecommerce-service"/>
    <springProperty scope="context" name="LOG_LEVEL"
                    source="logging.level.root" defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_PATH"
                    source="logging.file.path" defaultValue="/tmp/logs"/>

    <!-- =====================================================================
         CONSOLE APPENDER
         Used in development (default active profile)
         ================================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [reqId=%X{requestId:-NOREQID}] [userId=%X{userId:-anon}] %logger{50} - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- =====================================================================
         FILE APPENDER (Rolling)
         Used in production - one file per day, kept for 30 days
         ================================================================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Roll daily, keep 30 days, max 10GB total -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [reqId=%X{requestId:-NOREQID}] [userId=%X{userId:-anon}] %logger{50} - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- =====================================================================
         JSON FILE APPENDER (for log aggregation tools like ELK/Loki)
         Produces structured JSON logs that Logstash/Filebeat can parse
         ================================================================== -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-json.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- Simple structured JSON format readable by ELK stack -->
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS}","level":"%-5level","service":"${APP_NAME}","requestId":"%X{requestId:-}","userId":"%X{userId:-}","thread":"%thread","logger":"%logger{50}","message":"%msg"}%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- =====================================================================
         ASYNC WRAPPERS
         Async appenders prevent logging from blocking request threads.
         Queue size 512, discardingThreshold 0 = never discard (WARN/ERROR safe)
         ================================================================== -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="CONSOLE"/>
    </appender>

    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- =====================================================================
         LOGGER LEVELS
         ================================================================== -->

    <!-- Hibernate SQL logging - enable only in dev for debugging -->
    <springProfile name="dev">
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="ASYNC_CONSOLE"/>
        </logger>
        <logger name="org.hibernate.type.descriptor.sql" level="TRACE" additivity="false">
            <appender-ref ref="ASYNC_CONSOLE"/>
        </logger>
    </springProfile>

    <!-- Our application code -->
    <logger name="com.ecommerce" level="DEBUG" additivity="false">
        <springProfile name="dev,default">
            <appender-ref ref="ASYNC_CONSOLE"/>
        </springProfile>
        <springProfile name="prod">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="JSON_FILE"/>
        </springProfile>
    </logger>

    <!-- Spring framework - INFO only (very verbose at DEBUG) -->
    <logger name="org.springframework" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </logger>

    <!-- Eureka client - suppress heartbeat noise -->
    <logger name="com.netflix.eureka" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </logger>
    <logger name="com.netflix.discovery" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </logger>

    <!-- Kafka client logging -->
    <logger name="org.apache.kafka" level="WARN" additivity="false">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </logger>

    <!-- =====================================================================
         ROOT LOGGER
         ================================================================== -->
    <root level="${LOG_LEVEL}">
        <springProfile name="dev,default">
            <appender-ref ref="ASYNC_CONSOLE"/>
        </springProfile>
        <springProfile name="prod">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="JSON_FILE"/>
        </springProfile>
    </root>

</configuration>
